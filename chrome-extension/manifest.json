{
  "manifest_version": 3,
  "name": "Nova",
  "version": "1.2",
  "description": "Local security monitor",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "webNavigation",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Nova"
  },
  "host_permissions": [
    "<all_urls>",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
